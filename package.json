  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "start-server-and-test": "^3.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
