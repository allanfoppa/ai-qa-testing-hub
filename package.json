{
  "name": "ai-qa-testing-hub",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test:summarizer:back:all": "pnpm --filter ./src/suites/ai-text-summarizer-app/backend test:all",
    "test:summarizer:back:correctness": "pnpm --filter ./src/suites/ai-text-summarizer-app/backend test:correctness",
    "test:summarizer:back:contracts": "pnpm --filter ./src/suites/ai-text-summarizer-app/backend test:contracts",
    "test:summarizer:front:all": "pnpm --filter ./src/suites/ai-text-summarizer-app/frontend test:all",
    "test:summarizer:front:correctness": "pnpm --filter ./src/suites/ai-text-summarizer-app/frontend test:correctness",
    "test:summarizer:front:contracts": "pnpm --filter ./src/suites/ai-text-summarizer-app/frontend test:contracts",
    "test:summarizer:front:behavior": "pnpm --filter ./src/suites/ai-text-summarizer-app/frontend test:behavior",
    "test:rick:all": "pnpm --filter ./src/suites/rick-and-morty-graphs-and-stuff test:all",
    "test:rick:correctness": "pnpm --filter ./src/suites/rick-and-morty-graphs-and-stuff test:correctness",
    "test:rick:contracts": "pnpm --filter ./src/suites/rick-and-morty-graphs-and-stuff test:contracts",
    "test:rick:behavior": "pnpm --filter ./src/suites/rick-and-morty-graphs-and-stuff test:behavior",
    "report:gen": "node scripts/generate-report-template.js",
    "report:summarizer:back": "pnpm run report:gen ai-text-summarizer-app/backend",
    "report:summarizer:front": "pnpm run report:gen ai-text-summarizer-app/frontend",
    "report:rick": "pnpm run report:gen rick-and-morty-graphs-and-stuff",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
