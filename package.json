{
  "name": "ai-qa-testing-hub",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "// --- Run by specific path --- //": "",
    "test:summarizer:back": "jest --config src/engines/jest.config.ts src/suites/ai-text-summarizer-app/backend",
    "test:summarizer:front": "jest --config src/engines/jest.config.ts src/suites/ai-text-summarizer-app/frontend",
    "test:all:summarizer": "jest --config src/engines/jest.config.ts src/suites/ai-text-summarizer-app",
    "test:rick": "playwright test ./suites/rick-and-morty-graphs-and-stuff/ --config=src/engines/playwright.config.ts",
    "report:gen": "node scripts/generate-report-template.js",
    "report:summarizer:back": "pnpm run report:gen ai-text-summarizer-app/backend",
    "report:summarizer:front": "pnpm run report:gen ai-text-summarizer-app/frontend",
    "report:rick": "pnpm run report:gen rick-and-morty-graphs-and-stuff",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.58.2",
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
