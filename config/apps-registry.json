{
  "projects": [
    {
      "id": "ai-text-summarizer-backend",
      "name": "AI Text Summarizer",
      "type": "backend",
      "engine": "jest",
      "port": 3000,
      "baseUrl": "http://localhost:3000",
      "rootPath": "backend",
      "testFolder": "suites/ai-text-summarizer-app/backend",
      "repo": "allanfoppa/ai-text-summarizer-app",
      "prepare": "pnpm install && pnpm run build",
      "initApp": "pnpm run start:prod",
      "command": "pnpm run test:summarizer:back"
    },
    {
      "id": "ai-text-summarizer-frontend",
      "name": "AI Text Summarizer",
      "type": "frontend",
      "engine": "jest",
      "port": 3001,
      "baseUrl": "http://localhost:3001",
      "rootPath": "frontend",
      "testFolder": "suites/ai-text-summarizer-app/frontend",
      "repo": "allanfoppa/ai-text-summarizer-app",
      "prepare": "pnpm install && pnpm run build",
      "initApp": "pnpm run preview --port 3001 --strictPort",
      "command": "pnpm run test:summarizer:front"
    },
    {
      "id": "rick-and-morty-graphs-and-stuff",
      "name": "Rick and Morty Analytics",
      "type": "frontend",
      "engine": "playwright",
      "port": 3000,
      "baseUrl": "http://localhost:3000",
      "rootPath": "app",
      "testFolder": "suites/rick-and-morty-graphs-and-stuff",
      "repo": "allanfoppa/rick-and-morty-graphs-and-stuff",
      "prepare": "pnpm install",
      "initApp": "pnpm run start",
      "command": "pnpm run test:rick"
    }
  ]
}
