{
  "projects": [
    {
      "metadata": {
        "id": "ai-text-summarizer-backend",
        "name": "AI Text Summarizer",
        "workspace_name": "@hub/ai-text-summarizer-backend",
        "type": "backend"
      },
      "app": {
        "port": 3000,
        "baseUrl": "http://127.0.0.1:3000",
        "rootPath": "backend",
        "repo": "allanfoppa/ai-text-summarizer-app"
      },
      "execution": {
        "engine": "jest",
        "prepare": "build",
        "initApp": "ppx start-server-and-test 'pnpm run start' tcp:$PORT"
      }
    },
    {
      "metadata": {
        "id": "ai-text-summarizer-frontend",
        "name": "AI Text Summarizer",
        "workspace_name": "@hub/ai-text-summarizer-frontend",
        "type": "frontend"
      },
      "app": {
        "port": 4173,
        "baseUrl": "http://127.0.0.1:4173",
        "rootPath": "frontend",
        "repo": "allanfoppa/ai-text-summarizer-app"
      },
      "execution": {
        "engine": "jest",
        "prepare": "build",
        "initApp": "pnpm run preview --port $PORT --host 127.0.0.1 & npx wait-on http://127.0.0.1:$PORT -t 90000"
      }
    },
    {
      "metadata": {
        "id": "rick-and-morty-graphs-and-stuff",
        "name": "Rick and Morty Analytics",
        "workspace_name": "@hub/rick-and-morty-graphs-and-stuff",
        "type": "frontend"
      },
      "app": {
        "port": 3000,
        "baseUrl": "http://127.0.0.1:3000",
        "rootPath": "app",
        "repo": "allanfoppa/rick-and-morty-graphs-and-stuff"
      },
      "execution": {
        "engine": "playwright",
        "prepare": "build",
        "initApp": "pnpm run start & npx wait-on http://127.0.0.1:3000 -t 120000"
      }
    }
  ]
}
