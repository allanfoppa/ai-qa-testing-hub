{
  "projects": [
    {
      "metadata": {
        "id": "ai-text-summarizer-backend",
        "name": "AI Text Summarizer",
        "workspace_name": "@hub/ai-text-summarizer-backend",
        "type": "backend"
      },
      "app": {
        "port": 3000,
        "baseUrl": "http://127.0.0.1:3000",
        "rootPath": "backend",
        "repo": "allanfoppa/ai-text-summarizer-app"
      },
      "execution": {
        "engine": "jest",
        "prepare": "pnpm install && pnpm run build",
        "initApp": "pnpm run preview --port 3001 --strictPort & npx wait-on http://127.0.0.1:3001 -t 90000",
        "command": "pnpm run test:summarizer:back",
        "testFolder": "suites/ai-text-summarizer-app/backend"
      }
    },
    {
      "metadata": {
        "id": "ai-text-summarizer-frontend",
        "name": "AI Text Summarizer",
        "workspace_name": "@hub/ai-text-summarizer-frontend",
        "type": "frontend"
      },
      "app": {
        "port": 3001,
        "baseUrl": "http://127.0.0.1:3001",
        "rootPath": "frontend",
        "repo": "allanfoppa/ai-text-summarizer-app"
      },
      "execution": {
        "engine": "jest",
        "prepare": "pnpm install && pnpm run build",
        "initApp": "pnpm run preview --port 3001 --strictPort & npx wait-on http://127.0.0.1:3001 -t 90000",
        "command": "pnpm run test:summarizer:front",
        "testFolder": "suites/ai-text-summarizer-app/frontend"
      }
    },
    {
      "metadata": {
        "id": "rick-and-morty-graphs-and-stuff",
        "name": "Rick and Morty Analytics",
        "workspace_name": "@hub/rick-and-morty-graphs-and-stuff",
        "type": "frontend"
      },
      "app": {
        "port": 3000,
        "baseUrl": "http://127.0.0.1:3000",
        "rootPath": "app",
        "repo": "allanfoppa/rick-and-morty-graphs-and-stuff"
      },
      "execution": {
        "engine": "playwright",
        "prepare": "pnpm install",
        "initApp": "pnpm run start & npx wait-on http://127.0.0.1:3000 -t 120000",
        "command": "pnpm run test:rick",
        "testFolder": "suites/rick-and-morty-graphs-and-stuff"
      }
    }
  ]
}
