{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "strict": true,
        "outDir": "./dist",
        "types": [
            "node",
        ],
        "lib": [
            "ES2022"
        ]
    },
    "include": [
        "src/**/*.ts",
        "config/**/*.json"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "apps"
    ]
}
